# LLM Providers
OPENAI_API_KEY=sk-...          # needed for embeddings (text-embedding-3-small)
ANTHROPIC_API_KEY=sk-ant-...   # needed for synthesis (claude-sonnet-4-6)

# Extraction provider: "gemini" (free) or "openai"
EXTRACTION_PROVIDER=gemini
GEMINI_API_KEY=AIza...         # free at aistudio.google.com — 15 RPM, 1M tokens/day

# Cohere (reranker)
COHERE_API_KEY=...

# LangSmith (observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=postmortem-rag

# ChromaDB
# Set CHROMA_HOST/CHROMA_PORT to use Docker; leave unset to use embedded persistent mode
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./data/chroma_db

# Embedding model (Google text-embedding-004 — free tier, 768 dims)
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_BATCH_SIZE=100

# Optional: override the default model for the chosen provider
# Defaults: gemini → gemini-2.0-flash, openai → gpt-4o-mini
# EXTRACTION_MODEL=gemini-2.0-flash
SYNTHESIS_MODEL=claude-sonnet-4-6-20251001

# Paths
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
BM25_INDEX_PATH=./data/bm25_index.pkl
QA_PAIRS_PATH=./evaluation/results/qa_pairs.json
